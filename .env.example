# ════════════════════════════════════════════════════════════════════════════════
# CashDash.ai — Environment Variables
# Copy this to .env.local for local dev, or paste into Vercel Environment Variables
# ════════════════════════════════════════════════════════════════════════════════

# ─── Supabase (REQUIRED) ──────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY_HERE

# ─── AI Configuration ──────────────────────────────────────────────
# Provider: 'ollama' (cloud) | 'openai' | 'gemini'
AI_PROVIDER=ollama

# Ollama Cloud (default — free with ollama.com account)
# Sign in: ollama signin
# Get API key: https://ollama.com/settings/keys
# IMPORTANT: Base URL must be /v1 (OpenAI-compatible), NOT /api
AI_BASE_URL=https://ollama.com/v1
AI_MODEL=gemma4:31b-cloud
OLLAMA_API_KEY=your_ollama_api_key_here

# OpenAI (alternative — set AI_PROVIDER=openai)
# AI_API_KEY=sk-your-openai-key-here
# AI_BASE_URL=https://api.openai.com/v1
# AI_MODEL=gpt-4o-mini

# Google Gemini (alternative — set AI_PROVIDER=gemini)
# AI_API_KEY=your-gemini-key-here
# AI_MODEL=gemini-2.0-flash
# GOOGLE_GENERATIVE_AI_API_KEY=your-gemini-key-here

# Vercel AI Gateway (alternative — set AI_PROVIDER=gateway)
# AI_GATEWAY_API_KEY=your-vercel-ai-gateway-key
# AI_MODEL=google/gemma-4-31b-it

# ─── App Config ───────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=CashDash.ai
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
NEXT_PUBLIC_APP_DESCRIPTION=AI-powered personal finance tracker

# ─── Capacitor / Mobile Wrapper (Optional) ───────────────────────
# For Android emulator local dev use: http://10.0.2.2:3000
# For device testing use your machine LAN IP, e.g. http://192.168.1.20:3000
CAPACITOR_SERVER_URL=https://cashdash.ai

# ─── LemonSqueezy Subscriptions (Optional) ───────────────────────
LEMONSQUEEZY_WEBHOOK_SECRET=your-webhook-secret
LEMONSQUEEZY_API_KEY=your-api-key
LEMONSQUEEZY_PRO_VARIANT_ID=12345
LEMONSQUEEZY_FAMILY_VARIANT_ID=12346
LEMONSQUEEZY_BUSINESS_VARIANT_ID=12347

# ─── Feature Flags (Optional — all default to true) ──────────────
# FEATURE_AI_ASSISTANT=true
# FEATURE_AI_INSIGHTS=true
# FEATURE_DAILY_CHART=true
# FEATURE_CSV_EXPORT=true
# FEATURE_MULTI_CURRENCY=false
# FEATURE_BUDGET_ALERTS=false
