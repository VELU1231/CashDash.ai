# ─── Supabase ─────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY_HERE

# ─── AI Configuration ──────────────────────────────────────────
# Options: 'ollama' | 'openai' | 'gemini'
AI_PROVIDER=ollama

# Ollama (local or cloud — recommended free option)
AI_BASE_URL=http://localhost:11434
AI_MODEL=llama3.2

# OpenAI (optional - if using OpenAI instead)
# AI_PROVIDER=openai
# AI_API_KEY=sk-your-openai-key-here
# AI_MODEL=gpt-4o-mini
# AI_BASE_URL=https://api.openai.com/v1

# Gemini (optional)
# AI_PROVIDER=gemini
# AI_API_KEY=your-gemini-key-here
# AI_MODEL=gemini-1.5-flash

# ─── App Config ───────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=CashDash.ai
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_DESCRIPTION=AI-powered personal finance tracker
